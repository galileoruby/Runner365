@using System.Globalization
@{
    ViewData["Title"] = "Timeline - Chronicle Editorial";
    var eventsByYear = ViewBag.EventsByYear as Dictionary<int, List<RunnerMVC.Models.TimelineEvent>>;
    var availableYears = ViewBag.AvailableYears as List<int>;
    var currentYear = ViewBag.CurrentYear as int?;
}

<div class="chronicle-container" x-data="chronicleTimeline()">
    <!-- Sidebar Navigation -->
    <aside class="chronicle-sidebar">
        <div class="chronicle-header">
            <h1 class="chronicle-title">Chronicle Editorial</h1>
            <nav class="chronicle-nav">
                <button class="nav-tab" :class="{ 'active': activeTab === 'latest' }" 
                        @@click="activeTab = 'latest'">Latest</button>
                <button class="nav-tab active" :class="{ 'active': activeTab === 'archive' }" 
                        @@click="activeTab = 'archive'">Archive</button>
                <button class="nav-tab" :class="{ 'active': activeTab === 'analysis' }" 
                        @@click="activeTab = 'analysis'">Analysis</button>
            </nav>
        </div>

        <div class="timeline-section">
            <h2 class="section-title">
                <i class="bi bi-clock-history"></i> Timeline
            </h2>
            <p class="section-subtitle">Chronological News</p>
        </div>

        <!-- Years Navigation -->
        <nav class="years-nav">
            @foreach (var year in availableYears ?? new List<int>())
            {
                <button class="year-button" 
                        :class="{ 'active': selectedYear === @year }"
                        @@click="scrollToYear(@year)">
                    <i class="bi bi-calendar3"></i>
                    <span>@year</span>
                </button>
            }
            <button class="year-button archive-button">
                <i class="bi bi-archive"></i>
                <span>Archive</span>
            </button>
        </nav>

        <div class="sidebar-footer">
            <button class="btn-today" @@click="scrollToToday()">
                Go To Today
            </button>
            <div class="footer-links">
                <button class="footer-link">
                    <i class="bi bi-gear"></i>
                    <span>Settings</span>
                </button>
                <button class="footer-link">
                    <i class="bi bi-question-circle"></i>
                    <span>Support</span>
                </button>
            </div>
        </div>
    </aside>

    <!-- Main Content Area -->
    <main class="chronicle-main">
        <div class="search-bar">
            <i class="bi bi-search"></i>
            <input type="text" placeholder="Buscar en el archivo..." 
                   x-model="searchQuery" 
                   @@input="filterEvents()">
            <button class="btn-icon"><i class="bi bi-bookmark"></i></button>
            <button class="btn-icon"><i class="bi bi-person-circle"></i></button>
        </div>

        <div class="timeline-content">
            @if (eventsByYear != null)
            {
                @foreach (var yearGroup in eventsByYear.OrderByDescending(g => g.Key))
                {
                    var year = yearGroup.Key;
                    var isCurrentYear = year == currentYear;

                    <div class="year-section" :id="'year-' + @year" data-year="@year">
                        @foreach (var monthGroup in yearGroup.Value.GroupBy(e => e.Fecha.Month).OrderByDescending(g => g.Key))
                        {
                            var month = CultureInfo.GetCultureInfo("es-ES").DateTimeFormat.GetMonthName(monthGroup.Key);
                            var monthCapitalized = char.ToUpper(month[0]) + month.Substring(1);

                            <div class="month-section">
                                <h2 class="month-header">
                                    @monthCapitalized @year
                                    @if (isCurrentYear && monthGroup.Key == DateTime.Now.Month)
                                    {
                                        <span class="badge-current">ACTUALIDAD</span>
                                    }
                                </h2>

                                <div class="events-timeline">
                                    @foreach (var evento in monthGroup.OrderByDescending(e => e.Fecha))
                                    {
                                        <div class="event-item">
                                            <div class="event-date">
                                                <div class="date-marker"></div>
                                                <span class="date-text">@evento.Fecha.ToString("dd MMM", new CultureInfo("es-ES")).ToUpper()</span>
                                            </div>

                                            <div class="event-card">
                                                <span class="event-category">@evento.EtiquetaCategoria</span>
                                                <h3 class="event-title">@evento.Titulo</h3>
                                                <p class="event-description">@evento.Descripcion</p>
                                                @if (!string.IsNullOrEmpty(evento.EnlaceCompleto))
                                                {
                                                    <a href="@evento.EnlaceCompleto" class="event-link">
                                                        Leer crónica completa <i class="bi bi-arrow-right"></i>
                                                    </a>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </main>
</div>

@section Scripts {
    <script src="~/js/timeline.js" asp-append-version="true"></script>
}

@section Styles {
    <link rel="stylesheet" href="~/css/timeline.css" asp-append-version="true" />
}

 